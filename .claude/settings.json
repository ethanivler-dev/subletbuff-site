{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(git push * main*)",
      "Bash(git push * production*)",
      "Bash(git push origin main*)",
      "Bash(git push origin production*)",
      "Bash(git push --force*main*)",
      "Bash(git push --force*production*)"
    ]
  }
}
